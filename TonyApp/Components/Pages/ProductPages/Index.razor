@* 
Product List Page
Displays a grid of all products with filtering, sorting, and editing capabilities.
Uses DevExpress Blazor components for enhanced UI functionality.
*@
@page "/products"
@using Microsoft.EntityFrameworkCore
@using DevExpress.Blazor
@using TonyApp.Models
@using TonyApp.Data
@inject IDbContextFactory<TonyApp.Data.MyAppDbContext> DbFactory
@inject NavigationManager Navigation
@rendermode InteractiveServer

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
<PageTitle>Products Index</PageTitle>

<h1>Products</h1>

<DxGrid @ref="Grid"
        Data="@products"
        CssClass="products-grid"
        KeyFieldName="Id"
        ShowGroupPanel="true"
        ShowFilterRow="true"
        AllowGroup="true"
        ShowGroupedColumns="true"
        AutoExpandAllGroupRows="false"
        ShowSearchBox="true"
        AllowColumnReorder="true"
        AllowSort="true"
        SelectionMode="GridSelectionMode.Multiple"
        SelectAllCheckboxMode="GridSelectAllCheckboxMode.Mixed"
        AllowSelectRowByClick="true"
        FocusedRowEnabled="false"
        HighlightRowOnHover="true"
        GroupFooterDisplayMode="GridGroupFooterDisplayMode.IfExpanded"
        ColumnResizeMode="GridColumnResizeMode.ColumnsContainer"
        FilterMenuButtonDisplayMode="GridFilterMenuButtonDisplayMode.Always"
        EditMode="GridEditMode.EditRow"
        EditModelSaving="OnEditModelSaving"
        DataItemDeleting="OnDataItemDeleting"
        VirtualScrollingMode="GridVirtualScrollingMode.Rows"
        VirtualScrollingEnabled="@VirtualScrollingEnabled"
        PageSize="25"
        VirtualScrollMaxRequestItems="500"
        SkeletonRowsEnabled="true"
        ShowTotalSummary="true"
        ShowGroupSummary="true">

    <Columns>
        <DxGridSelectionColumn Width="60px" />

        <DxGridCommandColumn Width="100px" />

        <DxGridDataColumn FieldName="Name" Caption="Name" MinWidth="180" />
        <DxGridDataColumn FieldName="Description" Caption="Description" MinWidth="140" />
        <DxGridDataColumn FieldName="Category" Caption="Category" MinWidth="140" />
        <DxGridDataColumn FieldName="Price" Caption="Price" DisplayFormat="c2" MinWidth="150" />
        <DxGridDataColumn FieldName="Qty" Caption="Qty" DisplayFormat="n0" MinWidth="150" />

        <DxGridDataColumn FieldName="IsActive" Caption="Active" Width="110px">
            <CellDisplayTemplate Context="cellContext">
                @{
                    var isActive = (bool)cellContext.Grid.GetDataItemValue(cellContext.DataItem, "IsActive");
                }
                <span class="badge @(isActive ? "bg-success" : "bg-danger")">
                    @(isActive ? "Yes" : "No")
                </span>
            </CellDisplayTemplate>
        </DxGridDataColumn>

        <DxGridDataColumn FieldName="CreatedDate" Caption="Created" DisplayFormat="MMM dd, yyyy" Width="140px" />

        <DxGridDataColumn Caption="Actions" Width="120px" SearchEnabled="false">
            <CellDisplayTemplate Context="cellContext">
                @{
                    var id = cellContext.Grid.GetDataItemValue(cellContext.DataItem, "Id");
                }
                <a href="@($"/products/details?id={id}")" class="btn btn-success btn-sm">Details</a> | 
                <a href="@($"/products/delete?id={id}")" class="btn btn-danger btn-sm">Delete</a>
            </CellDisplayTemplate>
        </DxGridDataColumn>
    </Columns>

    <GroupSummary>
        <DxGridSummaryItem SummaryType="GridSummaryItemType.Count"
                           FieldName="Id"
                           DisplayText="Count: {0}" 
                           FooterColumnName="Name" />

        <DxGridSummaryItem SummaryType="GridSummaryItemType.Sum"
                           FieldName="Price"
                           DisplayText="Total Price: {0:c2}"
                           FooterColumnName="Price" />

        <DxGridSummaryItem SummaryType="GridSummaryItemType.Avg"
                           FieldName="Price"
                           DisplayText="Avg Price: {0:c2}"
                           FooterColumnName="Price" />

        <DxGridSummaryItem SummaryType="GridSummaryItemType.Sum"
                           FieldName="Qty"
                           DisplayText="Total Qty: {0:n0}"
                           FooterColumnName="Qty" />

        <DxGridSummaryItem SummaryType="GridSummaryItemType.Avg"
                           FieldName="Qty"
                           DisplayText="Avg Qty: {0:F1}"
                           FooterColumnName="Qty" />
    </GroupSummary>

    <TotalSummary>
        <DxGridSummaryItem SummaryType="GridSummaryItemType.Count"
                           FieldName="Id"
                           DisplayText="Total Items: {0}"
                           FooterColumnName="Name" />

        <DxGridSummaryItem SummaryType="GridSummaryItemType.Sum"
                           FieldName="Price"
                           DisplayText="Grand Total: {0:c2}"
                           FooterColumnName="Price" />

        <DxGridSummaryItem SummaryType="GridSummaryItemType.Avg"
                           FieldName="Price"
                           DisplayText="Overall Avg: {0:c2}"
                           FooterColumnName="Price" />

        <DxGridSummaryItem SummaryType="GridSummaryItemType.Sum"
                           FieldName="Qty"
                           DisplayText="Total Quantity: {0:n0}"
                           FooterColumnName="Qty" />

        <DxGridSummaryItem SummaryType="GridSummaryItemType.Avg"
                           FieldName="Qty"
                           DisplayText="Avg Quantity: {0:F1}"
                           FooterColumnName="Qty" />
    </TotalSummary>

    <ToolbarTemplate Context="gridToolbarContext">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
            <Items>
                <DxToolbarItem BeginGroup="true" Alignment="ToolbarItemAlignment.Left">
                    <Template Context="toolbar_item_context">
                        <div class="d-flex flex-row align-items-center h-100 me-3">
                            <DxCheckBox @bind-Checked="VirtualScrollingEnabled">
                                Enable Virtual Scrolling
                            </DxCheckBox>
                        </div>
                    </Template>
                </DxToolbarItem>

                <DxToolbarItem Alignment="ToolbarItemAlignment.Right"
                               Text="Column Chooser"
                               RenderStyle="ButtonRenderStyle.Secondary"
                               IconCssClass="bi bi-layout-three-columns"
                               Click="ColumnChooserButton_Click" />

                <DxToolbarItem Text="Add Product"
                               BeginGroup="true"
                               Alignment="ToolbarItemAlignment.Left"
                               RenderStyle="ButtonRenderStyle.Primary"
                               IconCssClass="bi bi-plus-circle"
                               Click="AddProduct" />

                <DxToolbarItem Text="Refresh"
                               Alignment="ToolbarItemAlignment.Left"
                               RenderStyle="ButtonRenderStyle.Secondary"
                               IconCssClass="bi bi-arrow-clockwise"
                               Click="RefreshGrid" />

                <DxToolbarItem Text="Clear Filters"
                               Alignment="ToolbarItemAlignment.Left"
                               RenderStyle="ButtonRenderStyle.Secondary"
                               IconCssClass="bi bi-funnel"
                               Click="ClearFilters" />
            </Items>
        </DxToolbar>
    </ToolbarTemplate>

</DxGrid>

@code {
    private DxGrid? Grid { get; set; }
    private List<Product> products = new();

    bool VirtualScrollingEnabled { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        await using var context = await DbFactory.CreateDbContextAsync();

        products = await context.Product
            .AsNoTracking()
            .OrderBy(p => p.Name)
            .ToListAsync();
    }

    private void AddProduct()
    {
        Navigation.NavigateTo("/products/create");
    }

    private async Task RefreshGrid()
    {
        await LoadProductsAsync();
        StateHasChanged();
    }

    private void ClearFilters()
    {
        Grid?.ClearFilter();
    }

    private async Task OnDataItemDeleting(GridDataItemDeletingEventArgs e)
    {
        var id = (Guid)e.Grid.GetDataItemValue(e.DataItem, "Id");

        await using var context = await DbFactory.CreateDbContextAsync();
        var entity = await context.Product.FindAsync(id);

        if (entity != null)
        {
            context.Remove(entity);
            await context.SaveChangesAsync();
        }

        await LoadProductsAsync();
    }

    private async Task OnEditModelSaving(GridEditModelSavingEventArgs e)
    {
        var editModel = (Product)e.EditModel;

        await using var context = await DbFactory.CreateDbContextAsync();

        Product entity;

        if (e.IsNew)
        {
            entity = new Product()
            {
                Id = Guid.NewGuid(),
                CreatedDate = DateTime.UtcNow
            };
            context.Product.Add(entity);
        }

        else
        {
            var key = ((Product)e.DataItem).Id;
            entity = await context.Product.FindAsync(key);

            if (entity == null) return;

            entity.LastModifiedDate = DateTime.UtcNow;
        }

        entity.Name = editModel.Name;
        entity.Description = editModel.Description;
        entity.Category = editModel.Category;
        entity.Price = editModel.Price;
        entity.Qty = editModel.Qty;
        entity.IsActive = editModel.IsActive;
        entity.Supplier = editModel.Supplier;
        entity.ImageUrl = editModel.ImageUrl;

        await context.SaveChangesAsync();
        await LoadProductsAsync();
    }

    void ColumnChooserButton_Click()
    {
        Grid.ShowColumnChooser();
    }
}
